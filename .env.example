# Database (Supabase)
# Transaction mode (port 6543) - for application queries
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session mode (port 5432) - for Prisma migrations
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Setup key (for initial database seeding via /api/setup?key=YOUR_KEY)
SETUP_KEY="your-setup-key-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Jurnalis Hukum Bandung"

# Google Analytics 4 — dapatkan Measurement ID di GA4 Admin > Data Streams > Web
# Format: G-XXXXXXXXXX. Kosongkan = tracking disabled.
NEXT_PUBLIC_GA_ID=""

# Vercel Cron Secret (for scheduled publishing)
CRON_SECRET="your-cron-secret-here"

# Email (Resend — https://resend.com, free 100/day)
RESEND_API_KEY="re_your-api-key-here"
EMAIL_FROM="JHB <noreply@jurnalishukumbandung.com>"

# Cloudflare (Untuk auto purge cache saat publish artikel)
# Dapatkan di Cloudflare Dashboard -> Website -> Overview (Zone ID kanan bawah)
# API Token: My Profile -> API Tokens -> Custom Token (Zone - Cache Purge - Edit)
CLOUDFLARE_ZONE_ID="your-zone-id"
CLOUDFLARE_API_TOKEN="your-api-token"

# Google Indexing API (Opsional, untuk indeks super cepat rank 1)
# Isi dengan seluruh string JSON dari Service Account Key. Jangan ada enter baris.
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account","project_id":"...}'

# Web Push (VAPID) — generate via: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key-here"
VAPID_PRIVATE_KEY="your-vapid-private-key-here"
VAPID_SUBJECT="mailto:redaksi@yourdomain.com"
