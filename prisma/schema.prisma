generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  EDITOR
  JOURNALIST
  CONTRIBUTOR
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum VerificationLabel {
  VERIFIED
  UNVERIFIED
  CORRECTION
  OPINION
}

enum ReportReason {
  HOAX
  INACCURATE
  SARA
  DEFAMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum AdType {
  IMAGE
  GIF
  HTML
}

enum AdSlot {
  HEADER
  SIDEBAR
  IN_ARTICLE
  FOOTER
  BETWEEN_SECTIONS
  POPUP
  FLOATING_BOTTOM
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  password         String
  name             String
  avatar           String?
  bio              String?
  role             Role       @default(JOURNALIST)
  specialization   String?
  phone            String?
  nomorKartuPers   String?
  organisasiPers   String?
  pendidikan       String?
  pengalaman       String?    @db.Text
  keahlian         String?
  portofolio       String?
  mediaSosial      String?
  alamat           String?
  isActive         Boolean    @default(true)
  twoFactorEnabled Boolean    @default(false)
  activeSessionId  String?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  articles         Article[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Article {
  id                 String            @id @default(cuid())
  title              String
  slug               String            @unique
  content            String            @db.Text
  excerpt            String?
  featuredImage      String?
  status             ArticleStatus     @default(DRAFT)
  verificationLabel  VerificationLabel @default(UNVERIFIED)
  readTime           Int?
  viewCount          Int               @default(0)
  publishedAt        DateTime?
  scheduledAt        DateTime?
  seoTitle           String?
  seoDescription     String?
  author             User              @relation(fields: [authorId], references: [id])
  authorId           String
  category           Category          @relation(fields: [categoryId], references: [id])
  categoryId         String
  tags               Tag[]
  sources            Source[]
  corrections        Correction[]
  reports            Report[]
  revisions          Revision[]
  comments           Comment[]
  reviewNote         String?
  reviewedBy         String?
  reviewedAt         DateTime?
  assignedEditorId   String?
  coAuthors          String?           @db.Text
  faqData            String?           @db.Text // JSON: [{q: "...", a: "..."}] — auto-generated FAQ for SEO
  lastIndexedAt      DateTime?
  indexStatus        String? // "submitted", "failed", "not_submitted"
  isAutoGenerated    Boolean           @default(false)
  sourceArticleId    String? // ID artikel asli yang di-paraphrase
  // Social publish per-article overrides (null = follow global settings)
  publishToInstagram Boolean?
  publishToFacebook  Boolean?
  socialCaptionIg    String?           @db.Text // manual override IG caption
  socialCaptionFb    String?           @db.Text // manual override FB caption
  socialFbFormat     String? // "link_share" | "photo" | "multi_photo"
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  sorotan      Sorotan[]
  socialPosts  SocialPost[]
  tiktokVideos TiktokVideo[]
  poll         Poll?

  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([assignedEditorId])
  @@map("articles")
}

// ───── Social Media Auto-Publish ─────

model SocialMediaSettings {
  id                     String    @id @default(cuid())
  // Meta OAuth
  metaAccessToken        String?   @db.Text
  metaRefreshToken       String?   @db.Text
  metaTokenExpiresAt     DateTime?
  fbPageId               String?
  fbPageName             String?
  igUserId               String?
  igAccountName          String?
  // AI caption
  captionPromptTemplate  String?   @db.Text
  captionSafetyRules     String?   @db.Text
  fixedHashtagsBrand     String[]  @default([])
  // Master switch
  autoPublishEnabled     Boolean   @default(false)
  // Draft mode — if true, publish creates drafts for review instead of posting directly
  draftModeEnabled       Boolean   @default(false)
  // Notifications
  notificationEmail      String?
  notificationWebhookUrl String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("social_media_settings")
}

model InstagramSettings {
  id                  String   @id @default(cuid())
  enabled             Boolean  @default(false)
  aspectRatio         String   @default("4:5") // "1:1" | "4:5" | "1.91:1"
  resizeStrategy      String   @default("smart") // "smart" | "letterbox"
  jpegQuality         Int      @default(85)
  watermarkPngUrl     String?
  watermarkConfig     Json? // position/opacity/size/padding
  hashtagCountTarget  Int      @default(12)
  fixedHashtagsIg     String[] @default([])
  captionToneOverride String?
  publishDelaySec     Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("instagram_settings")
}

model FacebookSettings {
  id                     String   @id @default(cuid())
  enabled                Boolean  @default(false)
  defaultPostFormat      String   @default("link_share") // "link_share" | "photo" | "multi_photo"
  aspectRatio            String   @default("1.91:1")
  resizeStrategy         String   @default("smart")
  jpegQuality            Int      @default(85)
  watermarkPngUrl        String?
  watermarkConfig        Json?
  hashtagCountTarget     Int      @default(4)
  fixedHashtagsFb        String[] @default([])
  captionToneOverride    String?
  publishDelaySec        Int      @default(300) // stagger 5min after IG
  linkPosition           String   @default("end") // "start" | "end"
  utmParams              Json? // { utm_source, utm_medium, utm_campaign }
  categoryFormatOverride Json? // { categoryId: "link_share"|"photo"|"multi_photo" }
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("facebook_settings")
}

model CtaTemplate {
  id             String   @id @default(cuid())
  name           String
  imageUrl       String
  isActive       Boolean  @default(true)
  rotationWeight Int      @default(1)
  createdAt      DateTime @default(now())

  @@map("cta_templates")
}

// Social Media Post Templates — used to composite article images with branded frames/text
model SocialTemplate {
  id               String   @id @default(cuid())
  name             String
  platform         String // "instagram" | "facebook" | "both"
  aspectRatio      String // "4:5" | "1:1" | "1.91:1"
  // Background overlay PNG — sits on TOP of the article photo (with transparent area for photo)
  templateImageUrl String
  // Photo slot position/size as percentage (0-1) of final canvas
  photoSlotX       Float    @default(0)
  photoSlotY       Float    @default(0)
  photoSlotWidth   Float    @default(1)
  photoSlotHeight  Float    @default(1)
  // Text layers: array of { text, x, y, fontSize, color, align, fontWeight, maxWidth }
  // text can contain placeholders: {{title}}, {{category}}, {{date}}, {{author}}
  textLayers       Json?
  isActive         Boolean  @default(true)
  isDefault        Boolean  @default(false) // default per platform
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([platform, isActive])
  @@map("social_templates")
}

model SocialPost {
  id               String    @id @default(cuid())
  article          Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId        String
  platform         String // "instagram" | "facebook"
  externalPostId   String? // ID dari Meta
  externalUrl      String?
  status           String    @default("pending") // "draft" | "pending" | "success" | "failed" | "deleted"
  postFormat       String? // "carousel" | "link_share" | "photo" | "multi_photo"
  captionFinal     String?   @db.Text
  renderedImageUrl String? // URL of rendered image (for draft preview)
  slidesCount      Int?
  publishedAt      DateTime?
  scheduledFor     DateTime?
  errorMessage     String?   @db.Text
  retryCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([articleId])
  @@index([platform, status])
  @@index([scheduledFor])
  @@map("social_posts")
}

// Sorotan = substantive summary pages (3 per article, each with unique angle)
// Each page has 300-500 words of standalone content + link to full article
model Sorotan {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String // Unique title for this angle
  content       String    @db.Text // 300-500 words substantive content
  angle         String // "kronologi" | "analisis" | "dampak"
  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId     String
  indexStatus   String? // "submitted", "failed", null
  lastIndexedAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([articleId])
  @@index([angle])
  @@index([indexStatus])
  @@map("sorotan")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  order       Int       @default(0)
  articles    Article[]
  polls       Poll[]

  @@map("categories")
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  articles Article[]

  @@map("tags")
}

model Source {
  id          String  @id @default(cuid())
  name        String
  title       String?
  institution String?
  url         String?
  article     Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String

  @@map("sources")
}

model Correction {
  id          String   @id @default(cuid())
  description String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  createdAt   DateTime @default(now())

  @@map("corrections")
}

model Revision {
  id        String   @id @default(cuid())
  content   String   @db.Text
  title     String
  changedBy String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime @default(now())

  @@map("revisions")
}

model Report {
  id        String       @id @default(cuid())
  reason    ReportReason
  detail    String?
  email     String?
  status    ReportStatus @default(PENDING)
  article   Article      @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  createdAt DateTime     @default(now())

  @@map("reports")
}

model Ad {
  id          String   @id @default(cuid())
  name        String
  type        AdType
  imageUrl    String?
  htmlCode    String?  @db.Text
  targetUrl   String?
  slot        AdSlot
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  priority    Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  targetPages String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ads")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  detail    String?
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model AIUsageLog {
  id           String   @id @default(cuid())
  userId       String
  userName     String
  feature      String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  articleTitle String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("ai_usage_logs")
}

model Comment {
  id          String   @id @default(cuid())
  content     String   @db.Text
  authorName  String
  authorEmail String
  isApproved  Boolean  @default(false)
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId   String
  parentId    String?
  createdAt   DateTime @default(now())

  @@index([articleId])
  @@map("comments")
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  url          String   @db.Text
  type         String
  size         Int
  caption      String?  @db.Text
  source       String?
  uploadedBy   String
  uploaderName String
  createdAt    DateTime @default(now())

  @@index([uploadedBy])
  @@map("media")
}

model CourtSchedule {
  id          String   @id @default(cuid())
  title       String // "Sidang Tipikor Dana Bansos Bandung"
  court       String // "PN Bandung", "PT Jabar", "MA RI"
  courtType   String   @default("umum") // "umum", "tipikor", "militer", "agama", "tun"
  caseNumber  String? // "123/Pid.Sus-TPK/2026/PN Bdg"
  defendant   String? // nama terdakwa
  judge       String? // nama hakim
  agenda      String? // "Pembacaan Tuntutan"
  date        DateTime
  time        String? // "09:00 WIB"
  location    String? // "Ruang Sidang 1, Lantai 2"
  status      String   @default("scheduled") // "scheduled", "live", "done", "postponed"
  isHighlight Boolean  @default(false)
  articleSlug String? // link ke artikel liputan
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, status])
  @@index([court])
  @@map("court_schedules")
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_settings")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "article_approved", "article_rejected", "article_published", "article_submitted", "new_review"
  title     String
  message   String
  link      String? // URL to navigate to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model RedaksiMember {
  id        String   @id @default(cuid())
  position  String
  name      String
  desc      String?
  photo     String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("redaksi_members")
}

model Poll {
  id         String       @id @default(cuid())
  question   String
  image      String?
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id])
  articleId  String?      @unique
  article    Article?     @relation(fields: [articleId], references: [id])
  isActive   Boolean      @default(true)
  order      Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  options    PollOption[]

  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  label     String
  votes     Int        @default(0)
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  pollVotes PollVote[]

  @@map("poll_options")
}

model PollVote {
  id          String     @id @default(cuid())
  optionId    String
  option      PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  ip          String
  fingerprint String?
  createdAt   DateTime   @default(now())

  @@unique([optionId, ip])
  @@index([ip])
  @@map("poll_votes")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model TargetKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  source    String   @default("manual") // "manual" | "ai_research"
  notes     String?  @db.Text // optional reasoning from AI (kenapa keyword ini relevan)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
  @@map("target_keywords")
}

// DictionaryEntry — kata yang dikecualikan dari AI typo check
// Shared JHB-wide: istilah hukum (KUHP, UU), nama tokoh, nama daerah, dll.
model DictionaryEntry {
  id          String   @id @default(cuid())
  word        String   @unique // lowercase normalized
  originalWord String? // preserving case for display
  category    String?  // "legal" | "person" | "place" | "other"
  addedBy     String   // userId
  addedByName String?  // snapshot nama
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([word])
  @@index([category])
  @@map("dictionary_entries")
}

// ═══════════════════════════════════════════════════════════════════
// TIKTOK AUTO-CONTENT SYSTEM
// ═══════════════════════════════════════════════════════════════════

// TiktokVideo — project video TikTok yang dirender dari kumpulan clip+foto+backsong
model TiktokVideo {
  id        String   @id @default(cuid())
  title     String // Judul project (internal)
  caption   String?  @db.Text // Caption yang akan dipost ke TikTok
  hashtags  String[] @default([]) // Hashtag array
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  articleId String? // Opsional: terkait artikel

  // Assets
  clips          TiktokClip[]
  overlays       TiktokOverlay[] // Multiple PNG overlays — each independently positioned
  backsong       TiktokBacksong? @relation(fields: [backsongId], references: [id], onDelete: SetNull)
  backsongId     String?
  backsongVolume Float           @default(0.5) // 0.0-1.0

  // Frame overlay style — applied to entire video (none|ticker-news|brand-green|breaking-news|minimal|lower-third|custom)
  frameStyle     String          @default("none")
  // Breaking news text for "breaking-news" frame style
  breakingText   String?         @db.Text

  // DEPRECATED: single overlay fields — kept for backwards compat, migration moves to TiktokOverlay table.
  // New code should use the overlays[] relation.
  overlayImageUrl String?
  overlayX        Float   @default(0.5)
  overlayY        Float   @default(0.85)
  overlayScale    Float   @default(1.0)
  overlayRotation Float   @default(0)
  overlayOpacity  Float   @default(1.0)

  // Subtitle display config (renders on top of video during export)
  subtitleEnabled  Boolean @default(false)
  subtitleY        Float   @default(0.85)  // 0-1 vertical position
  subtitleFontSize Int     @default(56)    // px at 1080 canvas width

  // Render status
  renderStatus    String    @default("draft") // draft|queued|rendering|rendered|failed
  renderedUrl     String? // URL hasil render MP4
  renderedSize    Int? // Bytes
  durationSec     Float? // Durasi akhir
  renderError     String?   @db.Text
  renderStartedAt DateTime?
  renderedAt      DateTime?

  // Publishing status
  publishStatus String    @default("not_published") // not_published|draft_tiktok|published|failed
  tiktokPostId  String? // ID post di TikTok
  tiktokUrl     String? // URL publik TikTok
  publishedAt   DateTime?
  publishError  String?   @db.Text

  // Meta
  createdBy     String // User ID
  createdByName String? // Snapshot nama (untuk tampilan)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([renderStatus])
  @@index([publishStatus])
  @@index([articleId])
  @@index([createdBy])
  @@map("tiktok_videos")
}

// TiktokOverlay — multiple PNG overlays per video, each independently positionable
model TiktokOverlay {
  id        String      @id @default(cuid())
  video     TiktokVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId   String
  imageUrl  String      // Public URL of overlay PNG (transparent)
  // Position normalized 0-1 relative to output canvas (1080x1920 default)
  x         Float       @default(0.5)   // center x
  y         Float       @default(0.5)   // center y
  scale     Float       @default(1.0)   // 0.1-3.0
  rotation  Float       @default(0)     // -180 to 180
  opacity   Float       @default(1.0)   // 0-1
  order     Int         @default(0)     // z-order (higher = on top)
  label     String?     // Optional name (e.g. "Logo JHB", "Watermark")
  createdAt DateTime    @default(now())

  @@index([videoId, order])
  @@map("tiktok_overlays")
}

// TiktokClip — satu segment (video atau foto) dalam project
model TiktokClip {
  id             String      @id @default(cuid())
  video          TiktokVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId        String
  order          Int // Urutan (0-indexed)
  type           String // video|image
  sourceUrl      String // URL file source (uploaded)
  sourceDuration Float? // Durasi asli (untuk video source)

  // Editing
  durationSec  Float // Durasi clip di output (untuk image: user-set; video: trim length)
  trimStart    Float?  @default(0) // Trim mulai dari detik (video only)
  textOverlay  String? // Teks caption
  textPosition String? @default("bottom") // preset: top|center|bottom|top-left|top-right|center-left|center-right|bottom-left|bottom-right
  textColor    String? @default("#FFFFFF")
  // Pixel-precise position (0-100% of width/height). If set, overrides textPosition.
  textX        Float?  // Horizontal position 0-100 (% from left)
  textY        Float?  // Vertical position 0-100 (% from top)
  textFontSize Int?    @default(54) // Font size in pixels at 1080x1920 render
  textRotation Int?    @default(0)  // Rotation in degrees
  // Auto-generated subtitles via Whisper — array of { start, end, text }
  subtitles    Json?   // [{start: 0, end: 2.5, text: "Hello"}, ...]
  transition   String? @default("none") // none|fade|slide|zoom
  kenBurns     Boolean @default(false) // Zoom pan untuk foto

  createdAt DateTime @default(now())

  @@index([videoId, order])
  @@map("tiktok_clips")
}

// TiktokBacksong — library musik background
model TiktokBacksong {
  id          String   @id @default(cuid())
  name        String
  url         String // Path audio file
  durationSec Float
  mood        String? // serius|dramatis|santai|urgent|netral
  license     String? // Info lisensi/atribusi
  isActive    Boolean  @default(true)
  uploadedBy  String
  createdAt   DateTime @default(now())

  videos TiktokVideo[]

  @@index([isActive, mood])
  @@map("tiktok_backsongs")
}

// TiktokSettings — konfigurasi global TikTok integration
model TiktokSettings {
  id      String  @id @default(cuid())
  enabled Boolean @default(false) // Master switch

  // OAuth credentials (perlu daftar app di developers.tiktok.com)
  clientKey      String? // App client key
  clientSecret   String?   @db.Text // App client secret
  accessToken    String?   @db.Text // Current access token
  refreshToken   String?   @db.Text // Refresh token (365 hari)
  tokenExpiresAt DateTime? // Access token expiry (24 jam)
  openId         String? // TikTok user open ID
  username       String? // @handle

  // Defaults untuk render
  defaultBacksongId String?
  defaultHashtags   String[] @default([])
  maxDurationSec    Int      @default(60)
  outputWidth       Int      @default(1080)
  outputHeight      Int      @default(1920)
  outputFps         Int      @default(30)

  // Publishing behavior
  autoPublishEnabled Boolean @default(false) // Auto publish setelah render
  draftModeEnabled   Boolean @default(true) // Upload ke TikTok sebagai draft (user finalize di app)
  aiCaptionEnabled   Boolean @default(true) // Auto-generate caption via AI
  aiHashtagEnabled   Boolean @default(true) // Auto-generate hashtag

  updatedAt DateTime @updatedAt

  @@map("tiktok_settings")
}
